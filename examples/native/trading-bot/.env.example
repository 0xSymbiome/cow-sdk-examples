# cow-trading-bot environment template.
# Copy to `.env` and fill in. `.env` is gitignored — never commit credentials.

# Chain. Sepolia testnet (11155111) is the only supported network for now; the
# token addresses below are Sepolia-specific.
COW_BOT_CHAIN_ID=11155111

# Required for every wallet-touching command (inspect/run/daemon/topup/approve).
COW_BOT_RPC_URL=https://sepolia.infura.io/v3/<your-key>
COW_BOT_PRIVATE_KEY=0x<64-hex-private-key-of-a-TEST-wallet>

# Safety gate. Must be exactly `yes` to allow any command that writes on-chain
# or posts orders (run/daemon/topup/approve). Read-only commands ignore it.
COW_BOT_WRITE=no

# Identity stamped into order app-data. Optional.
COW_BOT_APP_CODE=cow-trading-bot

# Default sell size in wei. 0.005 WETH clears the Sepolia liquidity floor;
# the 0.001 WETH default below it is often quoted as "no liquidity".
COW_BOT_SELL_AMOUNT_WEI=5000000000000000

# Log format: `pretty` (default, human-readable) or `json` (for log shippers).
COW_BOT_LOG_FORMAT=pretty

# Optional — required only for subgraph analytics in `inspect`/`history`.
THE_GRAPH_API_KEY=<the-graph-api-key>
