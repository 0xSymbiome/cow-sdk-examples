# Copy to .env (gitignored) and fill in. Only `trade` reads these; `prove-cap`
# needs nothing. Use a throwaway Sepolia test wallet — never a wallet with real
# funds. Fund it with a little Sepolia ETH/WETH and approve the vault relayer to
# get an accepted order rather than a typed "insufficient balance" rejection.
COW_BOT_PRIVATE_KEY=0x<64-hex-private-key-of-a-TEST-wallet>

# Must be exactly `yes` to sign and post. Anything else is a quote-only run.
COW_BOT_WRITE=no

# Sell size in wei. 0.005 WETH clears the Sepolia liquidity floor.
COW_BOT_SELL_AMOUNT_WEI=5000000000000000

# Identity stamped into the order app-data.
COW_BOT_APP_CODE=cow-agent-sandbox
